{
  "name": "Lab Hardware Inventory",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Lab Hardware Inventory",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "node --check server.js && node --check public/app.js",
  "postAttachCommand": "npm start",
  "customizations": {
    "vscode": {
      "extensions": [
        "github.vscode-github-actions"
      ]
    }
  }
}
